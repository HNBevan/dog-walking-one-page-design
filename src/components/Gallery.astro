---
const photos = [
  { src: "/dog-one.jpg", alt: "Dog on a walk at The Leas", caption: "The Leas" },
  { src: "/dog-two.jpg", alt: "Dog on a walk at Radnor Park", caption: "Radnor Park" },
  {
    src: "/dog-three.jpg",
    alt: "Dog on a walk at East Cliff and Warren Country Park",
    caption: "East Cliff and Warren",
  },
  { src: "/dog-four.jpg", alt: "Dog on a walk at Folkestone Downs", caption: "Folkestone Downs" },
  { src: "/dog-five.jpg", alt: "Dog on a walk at Lyminge Forest", caption: "Lyminge Forest" },
  { src: "/dog-six.jpg", alt: "Dog on a walk at Capel-le-Ferne", caption: "Capel-le-Ferne" },
];
---

<section id="gallery" class="relative bg-estate-black py-24 md:py-32 lg:py-40 overflow-hidden">
  <div class="mx-auto max-w-[1400px] px-5 md:px-10 lg:px-16 mb-10 lg:mb-16">
    <h2 data-split-reveal class="text-display-section text-balance-display">
      Some Of The Dogs We Walk.
    </h2>
  </div>

  <div
    class="gallery-viewport overflow-hidden"
    role="region"
    aria-label="Photos of dogs on Hound &amp; Heath walks"
  >
    <div class="gallery-track flex will-change-transform">
      {photos.map((photo) => (
        <figure class="gallery-item flex-none w-[72vw] sm:w-[42vw] lg:w-[26vw]">
          <div class="aspect-[4/5] overflow-hidden bg-estate-black-soft">
            <img src={photo.src} alt={photo.alt} class="h-full w-full object-cover" loading="eager" />
          </div>
          <figcaption class="mt-3 text-sm text-stone">{photo.caption}</figcaption>
        </figure>
      ))}
      {/* Duplicate set — makes the loop seamless */}
      {photos.map((photo) => (
        <figure class="gallery-item flex-none w-[72vw] sm:w-[42vw] lg:w-[26vw]" aria-hidden="true">
          <div class="aspect-[4/5] overflow-hidden bg-estate-black-soft">
            <img src={photo.src} alt={photo.alt} class="h-full w-full object-cover" loading="eager" />
          </div>
          <figcaption class="mt-3 text-sm text-stone">{photo.caption}</figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery-viewport {
    /* Fade the left and right edges so the loop feels seamless */
    mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 6%,
      black 94%,
      transparent 100%
    );
    -webkit-mask-image: linear-gradient(
      to right,
      transparent 0%,
      black 6%,
      black 94%,
      transparent 100%
    );
  }

  .gallery-item {
    /* margin-right instead of gap so every item (including the last)
       contributes an equal W+G slice — making scrollWidth/2 land exactly
       at the start of the duplicate set for a seamless loop */
    margin-right: 1.25rem;
  }

  @media (min-width: 768px) {
    .gallery-item {
      margin-right: 1.75rem;
    }
  }
</style>

<script>
  import { gsap } from "gsap";

  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const track = document.querySelector<HTMLElement>(".gallery-track");

  if (track && !reduceMotion) {
    // scrollWidth / 2 lands exactly at the start of the duplicate set
    // because every item has margin-right (so each slice = W + G)
    const loopWidth = track.scrollWidth / 2;

    const tween = gsap.to(track, {
      x: -loopWidth,
      duration: 32,
      ease: "none",
      repeat: -1,
    });

    // Pause on hover and keyboard focus so users can read captions
    track.addEventListener("mouseenter", () => tween.pause());
    track.addEventListener("mouseleave", () => tween.resume());
    track.addEventListener("focusin",    () => tween.pause());
    track.addEventListener("focusout",   () => tween.resume());
  }
</script>
