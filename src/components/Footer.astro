---
const year = new Date().getFullYear();
---

<footer class="bg-estate-black-soft border-t border-chalk-white/10 py-10">
  <div class="mx-auto max-w-[1400px] px-5 md:px-10 lg:px-16 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
    <div>
      <p class="font-display text-base font-semibold">Hound &amp; Heath</p>
      <p class="mt-1 text-sm text-stone">Folkestone, Kent &middot; hello@houndandheath.co.uk</p>
    </div>
    <nav class="flex items-center gap-6 text-sm text-stone">
      <a href="#about" class="hover:text-heath-tan transition-colors duration-300">Philosophy</a>
      <a href="#services" class="hover:text-heath-tan transition-colors duration-300">Rates</a>
      <a href="#gallery" class="hover:text-heath-tan transition-colors duration-300">Gallery</a>
      <a href="#reviews" class="hover:text-heath-tan transition-colors duration-300">Reviews</a>
      <a href="#area" class="hover:text-heath-tan transition-colors duration-300">Area</a>
